#include <iostream>
using namespace std;

// Structure for the game
struct TicTacToe {
    char board[3][3];
};

// Function to initialize the board
void initializeBoard(TicTacToe &game) {
    char num = '1';

    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            game.board[i][j] = num++;
        }
    }
}

// Function to display the board
void displayBoard(TicTacToe game) {
    cout << "\n";

    for (int i = 0; i < 3; i++) {
        cout << " ";
        for (int j = 0; j < 3; j++) {
            cout << game.board[i][j];

            if (j < 2)
                cout << " | ";
        }

        cout << "\n";

        if (i < 2)
            cout << "---|---|---\n";
    }

    cout << "\n";
}

// Function to check winner
bool checkWinner(TicTacToe game, char player) {

    // Check rows and columns
    for (int i = 0; i < 3; i++) {

        // Rows
        if (game.board[i][0] == player &&
            game.board[i][1] == player &&
            game.board[i][2] == player)
            return true;

        // Columns
        if (game.board[0][i] == player &&
            game.board[1][i] == player &&
            game.board[2][i] == player)
            return true;
    }

    // Diagonals
    if (game.board[0][0] == player &&
        game.board[1][1] == player &&
        game.board[2][2] == player)
        return true;

    if (game.board[0][2] == player &&
        game.board[1][1] == player &&
        game.board[2][0] == player)
        return true;

    return false;
}

// Function to make a move
void makeMove(TicTacToe &game, int choice, char player) {

    int row = (choice - 1) / 3;
    int col = (choice - 1) % 3;

    if (game.board[row][col] != 'X' &&
        game.board[row][col] != 'O') {

        game.board[row][col] = player;
    }
    else {
        cout << "Position already taken!\n";
    }
}

int main() {

    TicTacToe game;

    initializeBoard(game);

    int choice;
    char currentPlayer = 'X';

    for (int turn = 0; turn < 9; turn++) {

        displayBoard(game);

        cout << "Player " << currentPlayer
             << ", enter position (1-9): ";
        cin >> choice;

        if (choice < 1 || choice > 9) {
            cout << "Invalid choice!\n";
            turn--;
            continue;
        }

        int row = (choice - 1) / 3;
        int col = (choice - 1) % 3;

        // Check if position is already used
        if (game.board[row][col] == 'X' ||
            game.board[row][col] == 'O') {

            cout << "Position already taken!\n";
            turn--;
            continue;
        }

        makeMove(game, choice, currentPlayer);

        // Check winner
        if (checkWinner(game, currentPlayer)) {
            displayBoard(game);
            cout << "Player " << currentPlayer
                 << " wins!\n";
            return 0;
        }

        // Change player
        if (currentPlayer == 'X')
            currentPlayer = 'O';
        else
            currentPlayer = 'X';
    }

    displayBoard(game);
    cout << "It's a draw!\n";

    return 0;
}
